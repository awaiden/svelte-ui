{
	"name": "svelte-ui",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*",
		"examples/*"
	],
	"scripts": {
		"build": "turbo run build",
		"check-types": "turbo run check-types",
		"dev": "turbo run dev",
		"lint": "biome lint --write",
		"format": "biome format --write",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.2",
		"@types/bun": "latest",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"turbo": "^2.8.10"
	},
	"lint-staged": {
		"*.{js,ts,svelte}": "biome lint --write",
		"*.{js,ts,svelte,json,css,md}": "biome format --write"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"packageManager": "bun@1.3.6"
}
