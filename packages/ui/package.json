{
	"name": "@adn-ui/svelte",
	"version": "0.0.1",
	"keywords": [
		"svelte"
	],
	"files": [
		"dist",
		"!dist/**/*.spec.*",
		"!dist/**/*.test.*"
	],
	"type": "module",
	"sideEffects": [
		"**/*.css"
	],
	"types": "./dist/index.d.ts",
	"svelte": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./styles": {
			"default": "./dist/styles/index.css"
		}
	},
	"scripts": {
		"dev": "vite build --watch",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"storybook": "BROWSER=NONE storybook dev -p 6006",
		"build-storybook": "storybook build",
		"lint": "oxlint . && eslint .",
		"format": "prettier --write .",
		"add:component": "bun scripts/add-component.ts"
	},
	"dependencies": {
		"bits-ui": "^2.15.8",
		"lucide-svelte": "^0.574.0",
		"tailwind-merge": "^3.4.1",
		"tailwind-variants": "^3.2.2",
		"tailwindcss-animate": "^1.0.7"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@storybook/addon-svelte-csf": "^5.0.11",
		"@storybook/addon-themes": "^10.2.10",
		"@storybook/sveltekit": "^10.2.10",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-oxlint": "^1.51.0",
		"eslint-plugin-perfectionist": "^5.6.0",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"oxlint": "^1.51.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"storybook": "^10.2.10",
		"svelte": "^5.49.2",
		"svelte-check": "^4.3.6",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0"
	},
	"peerDependencies": {
		"svelte": "^5.0.0",
		"tailwindcss": "^4.0.0"
	}
}
